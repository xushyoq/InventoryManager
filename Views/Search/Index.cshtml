@model InventoryManager.Models.SearchResult
@{
    ViewData["Title"] = string.IsNullOrEmpty(Model.Query) ? Localizer["Search"].Value : string.Format(Localizer["SearchResultsFor"].Value, Model.Query);
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">
        <i class="bi bi-search me-2"></i>
        @(string.IsNullOrEmpty(Model.Query) ? Localizer["Search"] : Localizer["SearchResultsFor", Model.Query])
    </h2>

    @if (string.IsNullOrEmpty(Model.Query))
    {
        <p class="text-muted">@Localizer["EnterSearchQuery"]</p>
    }
    else
    {
        <!-- Инвентари -->
        <h4 class="fw-bold mt-4 mb-3">@Localizer["Inventories"] (@Model.Inventories.Count)</h4>
        @if (!Model.Inventories.Any())
        {
            <p class="text-muted">@Localizer["NothingFound"]</p>
        }
        else
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@Localizer["Name"]</th>
                                <th>@Localizer["Description"]</th>
                                <th>@Localizer["Category"]</th>
                                <th>@Localizer["Tags"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var inv in Model.Inventories)
                            {
                                <tr class="inventory-row" style="cursor: pointer;"
                                    data-details-url="@Url.Action("Details", "Inventory", new { inventoryId = inv.Id })">
                                    <td class="fw-medium">@inv.Name</td>
                                    <td class="text-muted small">@(inv.Description?.Length > 60 ? inv.Description[..60] + "..." : inv.Description ?? "—")</td>
                                    <td><span class="badge bg-primary-subtle text-primary rounded-pill">@inv.Category</span></td>
                                    <td>
                                        @if (inv.InventoryTags?.Any() == true)
                                        {
                                            @foreach (var it in inv.InventoryTags.Take(3))
                                            {
                                                <span class="badge bg-success-subtle text-success rounded-pill small me-1">@it.Tag?.Name</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Предметы (группировка по инвентарю) -->
        <h4 class="fw-bold mt-4 mb-3">@Localizer["Items"] (@Model.Items.Count)</h4>
        @if (!Model.Items.Any())
        {
            <p class="text-muted">@Localizer["NothingFound"]</p>
        }
        else
        {
            @foreach (var group in Model.Items.GroupBy(i => i.Inventory))
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-light">
                        <a asp-controller="Inventory" asp-action="Details" asp-route-inventoryId="@group.Key?.Id" class="fw-medium text-decoration-none">
                            @group.Key?.Name
                        </a>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>@Localizer["Inventory"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in group)
                                {
                                    <tr class="item-row" style="cursor: pointer;"
                                        data-details-url="@Url.Action("Details", "Inventory", new { inventoryId = item.InventoryId })">
                                        <td class="fw-medium">@item.CustomId</td>
                                        <td class="text-muted">@group.Key?.Name</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.inventory-row, .item-row').forEach(row => {
            row.addEventListener('click', function () {
                window.location.href = this.dataset.detailsUrl;
            });
        });
    </script>
}
