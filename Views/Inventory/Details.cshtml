@using System.Security.Claims
@model IEnumerable<InventoryManager.Models.Item>
@{
    ViewData["Title"] = Localizer["InventoryDetails"].Value;
    var inventory = ViewBag.Inventory as InventoryManager.Models.Inventory;
    var comments = ViewBag.Comments as IEnumerable<InventoryManager.Models.InventoryComment> ?? Enumerable.Empty<InventoryManager.Models.InventoryComment>();
    var accesses = ViewBag.Accesses as IEnumerable<InventoryManager.Models.InventoryAccess> ?? Enumerable.Empty<InventoryManager.Models.InventoryAccess>();

    var canEdit = ViewBag.CanEdit as bool? ?? false;
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center">
            <button onclick="history.back()" class="btn btn-outline-secondary btn-sm rounded-pill me-3">
                <i class="bi bi-arrow-left"></i>
            </button>
            <div>
                <h2 class="fw-bold mb-0">@inventory.Name</h2>
                <span class="badge bg-primary-subtle text-primary rounded-pill">@inventory.Category</span>
                @if (inventory.IsPublic)
                {
                    <span class="badge bg-success-subtle text-success rounded-pill ms-1">@Localizer["Public"]</span>
                }
                else
                {
                    <span class="badge bg-secondary-subtle text-secondary rounded-pill ms-1">@Localizer["Private"]</span>
                }
            </div>
        </div>
        @if (canEdit)
        {
            <a asp-action="Edit" asp-route-inventoryId="@inventory.Id" class="btn btn-outline-primary rounded-pill px-4">
                <i class="bi bi-pencil me-1"></i> @Localizer["InventorySettings"]
            </a>
        }
    </div>

    <!-- Вкладки -->
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link active" href="#items" data-bs-toggle="tab">
                <i class="bi bi-box me-1"></i> @Localizer["ItemsTab"]
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#discussion" data-bs-toggle="tab">
                <i class="bi bi-chat me-1"></i> @Localizer["Discussion"]
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#statistics" data-bs-toggle="tab">
                <i class="bi bi-bar-chart me-1"></i> @Localizer["Statistics"]
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#access" data-bs-toggle="tab">
                <i class="bi bi-people me-1"></i> @Localizer["AccessTab"]
            </a>
        </li>
    </ul>

    <!-- Контент вкладки Айтемы -->
    <div class="tab-content">
        <div class="tab-pane fade show active" id="items">

            @if (canEdit)
            {
                <!-- Тулбар -->
                <div class="d-flex align-items-center gap-2 mb-3">
                    <a asp-controller="Item" asp-action="Create" asp-route-inventoryId="@inventory.Id"
                           class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-plus-lg me-1"></i> @Localizer["Add"]
                    </a>
                    <button type="button" id="btnEdit" class="btn btn-outline-secondary rounded-pill px-4" disabled
                            onclick="editSelected()">
                        <i class="bi bi-pencil me-1"></i> @Localizer["Edit"]
                    </button>
                    <button type="button" id="btnDelete" class="btn btn-outline-danger rounded-pill px-4" disabled
                            data-bs-toggle="modal" data-bs-target="#deleteModal">
                        <i class="bi bi-trash me-1"></i> <span id="deleteLabel">@Localizer["Delete"]</span>
                    </button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <h5 class="text-muted mt-3">@Localizer["NoItems"]</h5>
                    @if (canEdit)
                    {
                        <p class="text-muted small">@Localizer["ClickAddToStart"]</p>
                    }
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    @if (canEdit)
                                    {
                                        <th style="width: 40px;">
                                            <input type="checkbox" id="selectAll" class="form-check-input" />
                                        </th>
                                    }
                                    <th>ID</th>
                                    @if (inventory.CustomString1State)
                                    {
                                        <th>@inventory.CustomString1Name</th>
                                    }
                                    @if (inventory.CustomString2State)
                                    {
                                        <th>@inventory.CustomString2Name</th>
                                    }
                                    @if (inventory.CustomString3State)
                                    {
                                        <th>@inventory.CustomString3Name</th>
                                    }
                                    @if (inventory.CustomText1State)
                                    {
                                        <th>@inventory.CustomText1Name</th>
                                    }
                                    @if (inventory.CustomText2State)
                                    {
                                        <th>@inventory.CustomText2Name</th>
                                    }
                                    @if (inventory.CustomText3State)
                                    {
                                        <th>@inventory.CustomText3Name</th>
                                    }
                                    @if (inventory.CustomInt1State)
                                    {
                                        <th>@inventory.CustomInt1Name</th>
                                    }
                                    @if (inventory.CustomInt2State)
                                    {
                                        <th>@inventory.CustomInt2Name</th>
                                    }
                                    @if (inventory.CustomInt3State)
                                    {
                                        <th>@inventory.CustomInt3Name</th>
                                    }
                                    @if (inventory.CustomBool1State)
                                    {
                                        <th>@inventory.CustomBool1Name</th>
                                    }
                                    @if (inventory.CustomBool2State)
                                    {
                                        <th>@inventory.CustomBool2Name</th>
                                    }
                                    @if (inventory.CustomBool3State)
                                    {
                                        <th>@inventory.CustomBool3Name</th>
                                    }
                                    @if (inventory.CustomLink1State)
                                    {
                                        <th>@inventory.CustomLink1Name</th>
                                    }
                                    @if (inventory.CustomLink2State)
                                    {
                                        <th>@inventory.CustomLink2Name</th>
                                    }
                                    @if (inventory.CustomLink3State)
                                    {
                                        <th>@inventory.CustomLink3Name</th>
                                    }
                                    <th>@Localizer["Created"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr style="cursor: pointer;" data-id="@item.Id"
                                        data-edit-url="@Url.Action("Edit", "Item", new { itemId = item.Id })">
                                        @if (canEdit)
                                        {
                                            <td onclick="event.stopPropagation()">
                                                <input type="checkbox" class="form-check-input row-checkbox" value="@item.Id" />
                                            </td>
                                        }
                                        <td class="fw-medium">@item.CustomId</td>
                                        @if (inventory.CustomString1State)
                                        {
                                            <td>@item.CustomString1</td>
                                        }
                                        @if (inventory.CustomString2State)
                                        {
                                            <td>@item.CustomString2</td>
                                        }
                                        @if (inventory.CustomString3State)
                                        {
                                            <td>@item.CustomString3</td>
                                        }
                                        @if (inventory.CustomText1State)
                                        {
                                            <td>@item.CustomText1</td>
                                        }
                                        @if (inventory.CustomText2State)
                                        {
                                            <td>@item.CustomText2</td>
                                        }
                                        @if (inventory.CustomText3State)
                                        {
                                            <td>@item.CustomText3</td>
                                        }
                                        @if (inventory.CustomInt1State)
                                        {
                                            <td>@item.CustomInt1</td>
                                        }
                                        @if (inventory.CustomInt2State)
                                        {
                                            <td>@item.CustomInt2</td>
                                        }
                                        @if (inventory.CustomInt3State)
                                        {
                                            <td>@item.CustomInt3</td>
                                        }
                                        @if (inventory.CustomBool1State)
                                        {
                                            <td>@(item.CustomBool1 == true ? Localizer["Yes"] : Localizer["No"])</td>
                                        }
                                        @if (inventory.CustomBool2State)
                                        {
                                            <td>@(item.CustomBool2 == true ? Localizer["Yes"] : Localizer["No"])</td>
                                        }
                                        @if (inventory.CustomBool3State)
                                        {
                                            <td>@(item.CustomBool3 == true ? Localizer["Yes"] : Localizer["No"])</td>
                                        }
                                        @if (inventory.CustomLink1State)
                                        {
                                            <td><a href="@item.CustomLink1" target="_blank">@item.CustomLink1</a></td>
                                        }
                                        @if (inventory.CustomLink2State)
                                        {
                                            <td><a href="@item.CustomLink2" target="_blank">@item.CustomLink2</a></td>
                                        }
                                        @if (inventory.CustomLink3State)
                                        {
                                            <td><a href="@item.CustomLink3" target="_blank">@item.CustomLink3</a></td>
                                        }
                                        <td class="text-muted small">@item.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <!-- Вкладка Обсуждение -->
        <div class="tab-pane fade" id="discussion">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-action="AddComment" method="post" class="mb-4">
                    <input type="hidden" name="inventoryId" value="@inventory.Id" />
                    <div class="d-flex gap-2">
                        <input type="text" name="text" class="form-control" placeholder="@Localizer["AddComment"].Value" maxlength="2000" required />
                        <button type="submit" class="btn btn-primary rounded-pill px-4">@Localizer["SendComment"]</button>
                    </div>
                </form>
            }
            @if (!comments.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-chat-dots display-1 text-muted"></i>
                    <h5 class="text-muted mt-3">@Localizer["NoComments"]</h5>
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var c in comments)
                    {
                        <div class="list-group-item border-0 border-bottom py-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <strong class="me-2">@(c.User?.Name ?? "—")</strong>
                                    <span class="text-muted small">@c.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                                </div>
                            </div>
                            <p class="mb-0 mt-1">@c.Text</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Вкладка Статистика -->
        <div class="tab-pane fade" id="statistics">
            @{
                var stats = ViewBag.Statistics as InventoryManager.Models.InventoryStatistics;
            }
            <div class="mb-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-box-seam display-4 text-primary"></i>
                        <h3 class="mt-2 mb-0">@(stats?.ItemsCount ?? 0)</h3>
                        <p class="text-muted mb-0">@Localizer["ItemsCount"]</p>
                    </div>
                </div>
            </div>
            @if (stats?.NumericStats?.Any() == true)
            {
                <h6 class="fw-semibold mb-2">@Localizer["Average"] / @Localizer["Min"] / @Localizer["Max"]</h6>
                <div class="row g-3 mb-4">
                    @foreach (var ns in stats.NumericStats)
                    {
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <h6 class="fw-semibold">@ns.Name</h6>
                                    <p class="mb-0 small text-muted">@Localizer["Average"]: @ns.Avg.ToString("F2") | @Localizer["Min"]: @ns.Min | @Localizer["Max"]: @ns.Max</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            @if (stats?.StringStats?.Any() == true)
            {
                <h6 class="fw-semibold mb-2">@Localizer["TopValues"]</h6>
                <div class="row g-3">
                    @foreach (var ss in stats.StringStats)
                    {
                        <div class="col-md-4">
                            <div class="card border-0 shadow-sm">
                                <div class="card-body">
                                    <h6 class="fw-semibold">@ss.Name</h6>
                                    <ul class="list-unstyled mb-0 small">
                                        @foreach (var t in ss.Top)
                                        {
                                            <li>@t.Value — @t.Count</li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            @if ((stats?.ItemsCount ?? 0) == 0 && (stats?.NumericStats?.Any() != true) && (stats?.StringStats?.Any() != true))
            {
                <p class="text-muted">@Localizer["NoDataYet"]</p>
            }
        </div>

        <!-- Вкладка Доступ -->
        <div class="tab-pane fade" id="access">
            @if (canEdit)
            {
                <form asp-action="GrantAccess" method="post" class="mb-4">
                    <input type="hidden" name="inventoryId" value="@inventory.Id" />
                    <div class="row g-2 align-items-end">
                        <div class="col-md-6">
                            <label class="form-label small text-muted">@Localizer["UserEmail"]</label>
                            <input type="email" name="userEmail" class="form-control" placeholder="user@example.com" required />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">@Localizer["GrantAccess"]</button>
                        </div>
                    </div>
                </form>
                @if (TempData["AccessError"] != null)
                {
                    <div class="alert alert-warning">@TempData["AccessError"]</div>
                }
            }
            @if (!accesses.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-people display-1 text-muted"></i>
                    <h5 class="text-muted mt-3">@Localizer["NoAccessGranted"]</h5>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@Localizer["Name"]</th>
                                    <th>Email</th>
                                    @if (canEdit)
                                    {
                                        <th></th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in accesses)
                                {
                                    <tr>
                                        <td class="fw-medium">@(a.User?.Name ?? "—")</td>
                                        <td class="text-muted small">@(a.User?.Email ?? "—")</td>
                                        @if (canEdit)
                                        {
                                            <td>
                                                <form asp-action="RevokeAccess" method="post" class="d-inline" onsubmit="return confirm('@Localizer["ConfirmDelete"].Value');">
                                                    <input type="hidden" name="inventoryId" value="@inventory.Id" />
                                                    <input type="hidden" name="userId" value="@a.UserId" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm">@Localizer["RevokeAccess"]</button>
                                                </form>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div id="locStrings" style="display:none"
     data-delete="@Localizer["Delete"].Value"
     data-delete-count="@Localizer["DeleteCount"].Value"
     data-confirm-items="@Localizer["ConfirmDeleteItems"].Value"
     data-confirm-items-suffix1="@Localizer["ConfirmDeleteItemsSuffix1"].Value"
     data-confirm-items-suffix-many="@Localizer["ConfirmDeleteItemsSuffixMany"].Value"></div>

<!-- Модальное окно -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">@Localizer["ConfirmDelete"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="deleteConfirmText" class="text-muted"></p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4"
                        data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                <form asp-controller="Item" asp-action="Delete" method="post" id="deleteForm">
                    <button type="submit" class="btn btn-danger rounded-pill px-4">@Localizer["Delete"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        @if (canEdit)
            {
                <text>
                        document.getElementById('selectAll')?.addEventListener('change', function () {
                            document.querySelectorAll('.row-checkbox').forEach(cb => cb.checked = this.checked);
                        updateToolbar();
                                                                    });

                                                                    document.querySelectorAll('.row-checkbox').forEach(cb => {
                            cb.addEventListener('change', updateToolbar);
                                                                    });

                        function getSelected() {
                                                                        return [...document.querySelectorAll('.row-checkbox:checked')].map(cb => cb.value);
                                                                    }

                        function updateToolbar() {
                                                                        const selected = getSelected();
                        const count = selected.length;
                        document.getElementById('btnEdit').disabled = count !== 1;
                        document.getElementById('btnDelete').disabled = count === 0;
                                                                        const loc = document.getElementById('locStrings').dataset;
                                                                        document.getElementById('deleteLabel').textContent = count > 0 ? loc.deleteCount.replace('{0}', count) : loc.delete;
                                                                    }

                        function editSelected() {
                                                                        const selected = getSelected();
                        if (selected.length === 1) {
                                                                            const row = document.querySelector(`.row-checkbox[value="${selected[0]}"]`).closest('tr');
                        window.location.href = row.dataset.editUrl;
                                                                        }
                                                                    }

                        document.getElementById('deleteModal').addEventListener('show.bs.modal', function () {
                                                                        const selected = getSelected();
                        const form = document.getElementById('deleteForm');
                                                                        form.querySelectorAll('input[name="itemIds"]').forEach(el => el.remove());
                                                                        selected.forEach(id => {
                                                                            const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'itemIds';
                        input.value = id;
                        form.appendChild(input);
                                                                        });
                        const loc = document.getElementById('locStrings').dataset;
                                                                        const fmt = loc.confirmItems;
                                                                        const s1 = loc.confirmItemsSuffix1 || '';
                                                                        const sMany = loc.confirmItemsSuffixMany || '';
                                                                        document.getElementById('deleteConfirmText').textContent =
                                                                        fmt.replace('{0}', selected.length).replace('{1}', selected.length === 1 ? s1 : sMany);
                                                                    });
                </text>
        }
    </script>
}