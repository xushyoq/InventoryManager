@model InventoryManager.Models.Inventory
@{
    ViewData["Title"] = Localizer["EditInventory"].Value;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="d-flex align-items-center mb-4">
                <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm rounded-pill me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="fw-bold mb-0">@Localizer["EditInventory"]</h2>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedById" />
                        <input type="hidden" asp-for="CreatedAt" />
                        <input type="hidden" asp-for="Version" />

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-medium">@Localizer["Name"]</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-medium">@Localizer["Description"]</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Category" class="form-label fw-medium">@Localizer["Category"]</label>
                            <select asp-for="Category" asp-items="ViewBag.Categories" class="form-select"></select>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input asp-for="IsPublic" class="form-check-input" type="checkbox" role="switch" />
                                <label asp-for="IsPublic" class="form-check-label">@Localizer["PublicInventory"]</label>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="TagsInput" class="form-label fw-medium">@Localizer["Tags"]</label>
                            <input type="text" name="TagsInput" id="TagsInput" class="form-control"
                                   value="@(string.Join(", ", Model.InventoryTags.Select(it => it.Tag?.Name ?? "")))"
                                   placeholder="@Localizer["TagsPlaceholder"]" />
                            <small class="text-muted">@Localizer["TagsInputHint"]</small>
                        </div>

                        <hr />
                        <h5 class="fw-bold mb-3">@Localizer["CustomFields"]</h5>

                        @{
                            var fieldGroups = new[]
                            {
                                new { Prefix = "CustomString", Label = Localizer["CustomStringFields"].Value, Icon = "bi-type" },
                                new { Prefix = "CustomText",   Label = Localizer["CustomTextFields"].Value, Icon = "bi-text-paragraph" },
                                new { Prefix = "CustomInt",    Label = Localizer["CustomIntFields"].Value, Icon = "bi-123" },
                                new { Prefix = "CustomBool",   Label = Localizer["CustomBoolFields"].Value, Icon = "bi-toggle-on" },
                                new { Prefix = "CustomLink",   Label = Localizer["CustomLinkFields"].Value, Icon = "bi-link-45deg" },
                            };
                        }

                        @foreach (var group in fieldGroups)
                        {
                            <div class="mb-3 p-3 border rounded">
                                <h6 class="text-muted mb-3">
                                    <i class="bi @group.Icon me-1"></i> @group.Label
                                </h6>
                                @for (int i = 1; i <= 3; i++)
                                {
                                    var stateProp = $"{group.Prefix}{i}State";
                                    var nameProp = $"{group.Prefix}{i}Name";
                                    var descProp = $"{group.Prefix}{i}Description";
                                    var showProp = $"{group.Prefix}{i}ShowInTable";
                                    var isEnabled = (bool?)Model.GetType().GetProperty(stateProp)?.GetValue(Model) == true;
                                    var nameVal = Model.GetType().GetProperty(nameProp)?.GetValue(Model)?.ToString();
                                    var descVal = Model.GetType().GetProperty(descProp)?.GetValue(Model)?.ToString();
                                    var showVal = (bool?)Model.GetType().GetProperty(showProp)?.GetValue(Model) == true;

                                    <div class="border rounded p-3 mb-2 bg-light">
                                        <div class="d-flex align-items-center gap-3 mb-2">
                                            <div class="form-check form-switch mb-0" title="@Localizer["EnableField"]">
                                                <input type="checkbox" name="@stateProp" value="true" class="form-check-input custom-field-toggle"
                                                       role="switch" @(isEnabled ? "checked" : "") />
                                                <input type="hidden" name="@stateProp" value="false" />
                                            </div>
                                            <input type="text" name="@nameProp" class="form-control form-control-sm"
                                                   placeholder="@string.Format(Localizer["FieldNamePlaceholder"].Value, i)" value="@nameVal" />
                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <input type="text" name="@descProp" class="form-control form-control-sm"
                                                   placeholder="@Localizer["FieldHintPlaceholder"]" value="@descVal" />
                                            <div class="form-check form-switch mb-0 text-nowrap" title="@Localizer["ShowInTable"]">
                                                <input type="checkbox" name="@showProp" value="true" class="form-check-input"
                                                       role="switch" @(showVal ? "checked" : "") />
                                                <input type="hidden" name="@showProp" value="false" />
                                                <label class="form-check-label small text-muted">@Localizer["ShowInTable"]</label>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-check-lg me-1"></i> @Localizer["Save"]
                            </button>
                            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">@Localizer["Cancel"]</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}