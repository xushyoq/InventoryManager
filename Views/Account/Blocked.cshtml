@{
    ViewData["Title"] = "Аккаунт заблокирован";
}

<div class="row justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5 text-center">
                <div class="mb-4">
                    <i class="bi bi-shield-exclamation display-1 text-danger"></i>
                </div>
                
                <h2 class="fw-bold mb-3">Аккаунт заблокирован</h2>
                <p class="text-muted mb-4">Ваш аккаунт был заблокирован. Обратитесь к администратору для уточнения причин.</p>

                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary rounded-3 px-4">
                    <i class="bi bi-arrow-left me-2"></i>На страницу входа
                </a>
            </div>
        </div>
    </div>
</div>
