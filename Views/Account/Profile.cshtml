@using System.Security.Claims
@{
    ViewData["Title"] = Localizer["Profile"].Value;
    var myInventories = ViewBag.MyInventories as IEnumerable<InventoryManager.Models.Inventory> ?? Enumerable.Empty<InventoryManager.Models.Inventory>();
    var inventoriesWithAccess = ViewBag.InventoriesWithAccess as IEnumerable<InventoryManager.Models.Inventory> ?? Enumerable.Empty<InventoryManager.Models.Inventory>();
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">@Localizer["Profile"]</h2>

    <h5 class="fw-semibold mb-3">@Localizer["MyInventories"]</h5>
    @if (!myInventories.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox display-1 text-muted"></i>
                <h5 class="text-muted mt-3">@Localizer["NoInventories"]</h5>
                <a asp-controller="Inventory" asp-action="Create" class="btn btn-primary rounded-pill mt-2">
                    <i class="bi bi-plus-lg me-1"></i> @Localizer["Create"]
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["Name"]</th>
                            <th>@Localizer["Category"]</th>
                            <th>@Localizer["Description"]</th>
                            <th>@Localizer["Created"]</th>
                            <th>@Localizer["Access"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in myInventories)
                        {
                            <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Details", "Inventory", new { inventoryId = inv.Id })'">
                                <td class="fw-medium">@inv.Name</td>
                                <td><span class="badge bg-primary-subtle text-primary rounded-pill">@inv.Category</span></td>
                                <td class="text-muted small">@(inv.Description?.Length > 50 ? inv.Description.Substring(0, 50) + "..." : inv.Description ?? "—")</td>
                                <td class="text-muted small">@inv.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (inv.IsPublic)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill"><i class="bi bi-globe me-1"></i>@Localizer["Public"]</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill"><i class="bi bi-lock me-1"></i>@Localizer["Private"]</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <h5 class="fw-semibold mb-3">@Localizer["InventoriesWithAccess"]</h5>
    @if (!inventoriesWithAccess.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-share display-1 text-muted"></i>
                <h5 class="text-muted mt-3">@Localizer["NoInventoriesWithAccess"]</h5>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@Localizer["Name"]</th>
                            <th>@Localizer["Category"]</th>
                            <th>@Localizer["Description"]</th>
                            <th>@Localizer["Author"]</th>
                            <th>@Localizer["Created"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in inventoriesWithAccess)
                        {
                            <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Details", "Inventory", new { inventoryId = inv.Id })'">
                                <td class="fw-medium">@inv.Name</td>
                                <td><span class="badge bg-primary-subtle text-primary rounded-pill">@inv.Category</span></td>
                                <td class="text-muted small">@(inv.Description?.Length > 50 ? inv.Description.Substring(0, 50) + "..." : inv.Description ?? "—")</td>
                                <td class="text-muted small">@(inv.CreatedBy?.Name ?? "—")</td>
                                <td class="text-muted small">@inv.CreatedAt.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
