@model InventoryManager.Models.Item
@{
    ViewData["Title"] = Localizer["EditItem"].Value;
    var inventory = ViewBag.Inventory as InventoryManager.Models.Inventory;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="d-flex align-items-center mb-4">
                <a asp-controller="Item" asp-action="Index" asp-route-inventoryId="@Model.InventoryId"
                       class="btn btn-outline-secondary btn-sm rounded-pill me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <h2 class="fw-bold mb-0">@Localizer["EditItem"]</h2>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-controller="Item" asp-action="Edit" method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="InventoryId" />
                        <input type="hidden" asp-for="CreatedById" />
                        <input type="hidden" asp-for="CreatedAt" />
                        <input type="hidden" asp-for="Version" />

                        <div class="mb-3">
                            <label class="form-label fw-medium">@Localizer["ItemId"]</label>
                            <input asp-for="CustomId" class="form-control" />
                        </div>

                        @if (inventory.CustomString1State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomString1Name</label>
                                <input asp-for="CustomString1" class="form-control" placeholder="@inventory.CustomString1Description" />
                                @if (!string.IsNullOrEmpty(inventory.CustomString1Description)) { <div class="form-text">@inventory.CustomString1Description</div> }
                            </div>
                        }
                        @if (inventory.CustomString2State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomString2Name</label>
                                <input asp-for="CustomString2" class="form-control" placeholder="@inventory.CustomString2Description" />
                                @if (!string.IsNullOrEmpty(inventory.CustomString2Description)) { <div class="form-text">@inventory.CustomString2Description</div> }
                            </div>
                        }
                        @if (inventory.CustomString3State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomString3Name</label>
                                <input asp-for="CustomString3" class="form-control" placeholder="@inventory.CustomString3Description" />
                                @if (!string.IsNullOrEmpty(inventory.CustomString3Description)) { <div class="form-text">@inventory.CustomString3Description</div> }
                            </div>
                        }
                        @if (inventory.CustomText1State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomText1Name</label>
                                <textarea asp-for="CustomText1" class="form-control" rows="3" placeholder="@inventory.CustomText1Description"></textarea>
                                @if (!string.IsNullOrEmpty(inventory.CustomText1Description)) { <div class="form-text">@inventory.CustomText1Description</div> }
                            </div>
                        }
                        @if (inventory.CustomText2State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomText2Name</label>
                                <textarea asp-for="CustomText2" class="form-control" rows="3" placeholder="@inventory.CustomText2Description"></textarea>
                                @if (!string.IsNullOrEmpty(inventory.CustomText2Description)) { <div class="form-text">@inventory.CustomText2Description</div> }
                            </div>
                        }
                        @if (inventory.CustomText3State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomText3Name</label>
                                <textarea asp-for="CustomText3" class="form-control" rows="3" placeholder="@inventory.CustomText3Description"></textarea>
                                @if (!string.IsNullOrEmpty(inventory.CustomText3Description)) { <div class="form-text">@inventory.CustomText3Description</div> }
                            </div>
                        }
                        @if (inventory.CustomInt1State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomInt1Name</label>
                                <input asp-for="CustomInt1" type="number" step="1" class="form-control" placeholder="@inventory.CustomInt1Description" />
                                @if (!string.IsNullOrEmpty(inventory.CustomInt1Description)) { <div class="form-text">@inventory.CustomInt1Description</div> }
                            </div>
                        }
                        @if (inventory.CustomInt2State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomInt2Name</label>
                                <input asp-for="CustomInt2" type="number" step="1" class="form-control" placeholder="@inventory.CustomInt2Description" />
                                @if (!string.IsNullOrEmpty(inventory.CustomInt2Description)) { <div class="form-text">@inventory.CustomInt2Description</div> }
                            </div>
                        }
                        @if (inventory.CustomInt3State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomInt3Name</label>
                                <input asp-for="CustomInt3" type="number" step="1" class="form-control" placeholder="@inventory.CustomInt3Description" />
                                @if (!string.IsNullOrEmpty(inventory.CustomInt3Description)) { <div class="form-text">@inventory.CustomInt3Description</div> }
                            </div>
                        }
                        @if (inventory.CustomBool1State)
                        {
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="CustomBool1" type="checkbox" class="form-check-input" role="switch" />
                                    <label class="form-check-label">@inventory.CustomBool1Name</label>
                                </div>
                                @if (!string.IsNullOrEmpty(inventory.CustomBool1Description)) { <div class="form-text">@inventory.CustomBool1Description</div> }
                            </div>
                        }
                        @if (inventory.CustomBool2State)
                        {
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="CustomBool2" type="checkbox" class="form-check-input" role="switch" />
                                    <label class="form-check-label">@inventory.CustomBool2Name</label>
                                </div>
                                @if (!string.IsNullOrEmpty(inventory.CustomBool2Description)) { <div class="form-text">@inventory.CustomBool2Description</div> }
                            </div>
                        }
                        @if (inventory.CustomBool3State)
                        {
                            <div class="mb-3">
                                <div class="form-check form-switch">
                                    <input asp-for="CustomBool3" type="checkbox" class="form-check-input" role="switch" />
                                    <label class="form-check-label">@inventory.CustomBool3Name</label>
                                </div>
                                @if (!string.IsNullOrEmpty(inventory.CustomBool3Description)) { <div class="form-text">@inventory.CustomBool3Description</div> }
                            </div>
                        }
                        @if (inventory.CustomLink1State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomLink1Name</label>
                                <input asp-for="CustomLink1" type="url" class="form-control" placeholder="@(inventory.CustomLink1Description ?? "https://")" />
                                @if (!string.IsNullOrEmpty(inventory.CustomLink1Description)) { <div class="form-text">@inventory.CustomLink1Description</div> }
                            </div>
                        }
                        @if (inventory.CustomLink2State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomLink2Name</label>
                                <input asp-for="CustomLink2" type="url" class="form-control" placeholder="@(inventory.CustomLink2Description ?? "https://")" />
                                @if (!string.IsNullOrEmpty(inventory.CustomLink2Description)) { <div class="form-text">@inventory.CustomLink2Description</div> }
                            </div>
                        }
                        @if (inventory.CustomLink3State)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-medium">@inventory.CustomLink3Name</label>
                                <input asp-for="CustomLink3" type="url" class="form-control" placeholder="@(inventory.CustomLink3Description ?? "https://")" />
                                @if (!string.IsNullOrEmpty(inventory.CustomLink3Description)) { <div class="form-text">@inventory.CustomLink3Description</div> }
                            </div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-check-lg me-1"></i> @Localizer["Save"]
                            </button>
                            <a asp-controller="Item" asp-action="Index" asp-route-inventoryId="@inventory.Id"
                               class="btn btn-outline-secondary rounded-pill px-4">@Localizer["Cancel"]</a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>