@using InventoryManager.Models
@{
    ViewData["Title"] = "Главная";
    var latestInventories = ViewBag.LatestInventories as List<Inventory> ?? new List<Inventory>();
    var popularInventories = ViewBag.PopularInventories as List<Inventory> ?? new List<Inventory>();
    var tagCloud = ViewBag.TagCloud as List<TagCloudItem> ?? new List<TagCloudItem>();
    var selectedTag = ViewBag.SelectedTag as string;
}

<div class="container py-4">

    <div class="row g-4">

        <!-- Последние инвентари -->
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">
                    <i class="bi bi-clock-history me-2 text-primary"></i>Последние инвентари
                </h4>
            </div>

            @if (!latestInventories.Any())
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-inbox display-4"></i>
                    <p class="mt-2">Пока нет инвентарей</p>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Название</th>
                                    <th>Описание</th>
                                    <th>Категория</th>
                                    <th>Теги</th>
                                    <th>Доступ</th>
                                    <th>Автор</th>
                                    <th>Создано</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inventory in latestInventories)
                                {
                                    <tr class="inventory-row" style="cursor: pointer;"
                                        data-details-url="@Url.Action("Details", "Inventory", new { inventoryId = inventory.Id })">
                                        <td class="fw-medium">@inventory.Name</td>
                                        <td class="text-muted small">
                                            @(inventory.Description?.Length > 60
                                                ? inventory.Description.Substring(0, 60) + "..."
                                                : inventory.Description ?? "—")
                                        </td>
                                        <td>
                                            <span class="badge bg-primary-subtle text-primary rounded-pill">
                                                @inventory.Category
                                            </span>
                                        </td>
                                        <td>
                                            @if (inventory.InventoryTags?.Any() == true)
                                            {
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var it in inventory.InventoryTags.Take(3))
                                                    {
                                                        <span class="badge bg-success-subtle text-success rounded-pill small">@it.Tag?.Name</span>
                                                    }
                                                    @if (inventory.InventoryTags.Count > 3)
                                                    {
                                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill small">+@(inventory.InventoryTags.Count - 3)</span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (inventory.IsPublic)
                                            {
                                                <span class="badge bg-success-subtle text-success rounded-pill">
                                                    <i class="bi bi-globe me-1"></i>Публичный
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary rounded-pill">
                                                    <i class="bi bi-lock me-1"></i>Приватный
                                                </span>
                                            }
                                        </td>
                                        <td class="text-muted small">@inventory.CreatedById</td>
                                        <td class="text-muted small">@inventory.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <!-- Популярные инвентари -->
        <div class="col-12 mt-2">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">
                    <i class="bi bi-fire me-2 text-danger"></i>Топ-5 популярных инвентарей
                </h4>
            </div>

            @if (!popularInventories.Any())
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-bar-chart display-4"></i>
                    <p class="mt-2">Пока нет данных</p>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Название</th>
                                    <th>Описание</th>
                                    <th>Категория</th>
                                    <th>Теги</th>
                                    <th>Доступ</th>
                                    <th>Предметов</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int rank = 1; }
                                @foreach (var inventory in popularInventories)
                                {
                                    <tr class="inventory-row" style="cursor: pointer;"
                                        data-details-url="@Url.Action("Details", "Inventory", new { inventoryId = inventory.Id })">
                                        <td class="fw-bold text-muted">@rank</td>
                                        <td class="fw-medium">@inventory.Name</td>
                                        <td class="text-muted small">
                                            @(inventory.Description?.Length > 60
                                                ? inventory.Description.Substring(0, 60) + "..."
                                                : inventory.Description ?? "—")
                                        </td>
                                        <td>
                                            <span class="badge bg-primary-subtle text-primary rounded-pill">
                                                @inventory.Category
                                            </span>
                                        </td>
                                        <td>
                                            @if (inventory.InventoryTags?.Any() == true)
                                            {
                                                <div class="d-flex flex-wrap gap-1">
                                                    @foreach (var it in inventory.InventoryTags.Take(3))
                                                    {
                                                        <span class="badge bg-success-subtle text-success rounded-pill small">@it.Tag?.Name</span>
                                                    }
                                                    @if (inventory.InventoryTags.Count > 3)
                                                    {
                                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill small">+@(inventory.InventoryTags.Count - 3)</span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (inventory.IsPublic)
                                            {
                                                <span class="badge bg-success-subtle text-success rounded-pill">
                                                    <i class="bi bi-globe me-1"></i>Публичный
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary rounded-pill">
                                                    <i class="bi bi-lock me-1"></i>Приватный
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-success-subtle text-success rounded-pill">
                                                @inventory.Items.Count
                                            </span>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <!-- Облако тегов -->
        <div class="col-12 mt-2">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0">
                    <i class="bi bi-tags me-2 text-success"></i>Теги
                </h4>
                @if (!string.IsNullOrEmpty(selectedTag))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill">Сбросить фильтр</a>
                }
            </div>
            <div class="card border-0 shadow-sm p-4">
                @if (!tagCloud.Any())
                {
                    <p class="text-muted mb-0">
                        <i class="bi bi-info-circle me-1"></i>Теги появятся здесь после их добавления к инвентарям.
                    </p>
                }
                else
                {
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var t in tagCloud)
                        {
                            var tagName = t.Name;
                            var count = t.Count;
                            var isActive = string.Equals(tagName, selectedTag, StringComparison.OrdinalIgnoreCase);
                            <a asp-action="Index" asp-route-tag="@tagName"
                               class="badge @(isActive ? "bg-success" : "bg-success-subtle text-success") rounded-pill text-decoration-none py-2 px-3">
                                @tagName <span class="opacity-75">(@count)</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.inventory-row').forEach(row => {
            row.addEventListener('click', function () {
                window.location.href = this.dataset.detailsUrl;
            });
        });
    </script>
}
